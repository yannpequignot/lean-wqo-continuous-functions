import WqoContinuousFunctions.ScatFun.ReflectLevel
import WqoContinuousFunctions.ScatFun.Generators.Defs
import WqoContinuousFunctions.ScatFun.LevelsFinitelyGenerated.GlList
import WqoContinuousFunctions.CenteredFunctions.FinitenessHelpers

open scoped Topology
open Set Function TopologicalSpace Classical

set_option autoImplicit false

noncomputable section

/-!
# From finite generation to 2-BQO, level by level

Bridges the level-by-level finite-generation results (`Generators_zero_finitely_generates`,
`Generators_one_finitely_generates`, `Generators_lambda_finitely_generates`,
`Generators_lambdaPlusOne_finitely_generates`, `Generators_two_finitely_generates`) to the
2-BQO statements needed to *state* the extra hypothesis those successor-case theorems require
(`hbqo : TwoBQO (ScatFun.LevelLT.reduces (lam + 1))`), without going through the (still
unproven) global `ScatFun.levels_finitely_generated`.

* `Level.isTwoBQO_of_FG` ÔÇö a single level `╬▓`'s finite generation gives 2-BQO of `Level ╬▓`
  (the same argument as `ScatFun.Level.isTwoBQO` in `MainResults/ScatFunBQO.lean`, parametrised
  by an explicit finite-generation hypothesis instead of the global theorem).
* `LevelLT.isTwoBQO_of_FG_below` ÔÇö finite generation at every `╬▓ < ╬▒` gives 2-BQO of
  `LevelLT ╬▒`, via `bad_restricts_to_level` (any bad pair-sequence on `LevelLT ╬▒` restricts to a
  single level `╬▓ < ╬▒`, contradicting 2-BQO there).
* `FinGl_mono_of_subset` ÔÇö `FinGl` is monotone under `Finset`-inclusion of the generating
  family: reuses `finGl_glList_of_forall_mem` (every block of a finite gluing over `S` is
  literally a member of `S`, hence of any `S' Ôèç S`) and `finGl_closed_equiv`.
* `Generators_mono_of_le` ÔÇö for `lam` limit-or-zero, `Generators (lam+k) Ôèå Generators (lam+n)`
  whenever `k Ôëñ n` (monotonicity of the block recursion `GenBlock`, `GenBlock_subset_succ`).
* `LevelInter_finitelyGenerated` ÔÇö for `lam` limit-or-zero and `n : Ôäò`, if every level `lam+k`
  (`k Ôëñ n`) is finitely generated by its own `Generators (lam+k)`, then the whole interval
  `LevelInter lam (lam+n)` is finitely generated by the top-level family `Generators (lam+n)`
  alone (via `Generators_mono_of_le` + `FinGl_mono_of_subset`).  This is exactly the `hgen`
  hypothesis consumed by `finitenessOfCenteredFunctions` (`CenteredFunctions/Finiteness.lean`).
-/

namespace ScatFun

/-- **A single level's 2-BQO from its finite generation.**  By `FinGl.isTwoBQO`, `FinGl B` is
2-BQO for any finite `B`; pull back along the inclusion `Level ╬▓ Ôå¬ FinGl B` witnessed by `hB`. -/
theorem Level.isTwoBQO_of_FG {╬▓ : Ordinal.{0}}
    (hB : ÔêÇ F : ScatFun, CBRank F.func = ╬▓ ÔåÆ F Ôêê FinGl (Generators ╬▓).toFinFun) :
    TwoBQO (ScatFun.Level.reduces ╬▓) :=
  (ScatFun.FinGl.isTwoBQO (ScatFun.Generators ╬▓).toFinFun).comap
    (fun F : ScatFun.Level ╬▓ => Ôş¿F.val, hB F.val F.propÔş®)

/-- **`LevelLT ╬▒` is 2-BQO from finite generation at every level below `╬▒`.**

Given a bad pair-sequence `f` on `LevelLT ╬▒`, forget to a bad pair-sequence on `ScatFun` and
apply `bad_restricts_to_level`: it restricts to a single level `╬▓ < ¤ëÔéü`.  Since every value of
`f` has `CBRank < ╬▒`, so does the restricted subsequence, hence `╬▓ < ╬▒`; `hFG ╬▓` then gives
2-BQO of `Level ╬▓` (`Level.isTwoBQO_of_FG`), contradicting the restricted subsequence's
badness. -/
theorem LevelLT.isTwoBQO_of_FG_below {╬▒ : Ordinal.{0}}
    (hFG : ÔêÇ ╬▓ < ╬▒, ÔêÇ F : ScatFun, CBRank F.func = ╬▓ ÔåÆ F Ôêê FinGl (Generators ╬▓).toFinFun) :
    TwoBQO (ScatFun.LevelLT.reduces ╬▒) := by
  rw [TwoBQO.iff_noBad]
  rintro Ôş¿f, hbadÔş®
  have hbad' : PairSeq.IsBad ScatFun.Reduces (fun m n h => (f m n h).val) :=
    fun m n l hmn hnl => hbad m n l hmn hnl
  obtain Ôş¿╬▓, h╬▓lt, e, he, hbad_level, hrankÔş® :=
    ScatFun.bad_restricts_to_level (fun m n h => (f m n h).val) hbad'
  have h01 : CBRank (f (e 0) (e 1) (he (by norm_num))).val.func = ╬▓ := hrank 0 1 (by norm_num)
  have h╬▓╬▒ : ╬▓ < ╬▒ := h01 Ôû© (f (e 0) (e 1) (he (by norm_num))).prop
  let f_╬▓ : PairSeq (ScatFun.Level ╬▓) :=
    fun m n h => Ôş¿PairSeq.restrict (fun m n h => (f m n h).val) e he m n h, hrank m n hÔş®
  exact (TwoBQO.iff_noBad _).mp (ScatFun.Level.isTwoBQO_of_FG (hFG ╬▓ h╬▓╬▒))
    Ôş¿f_╬▓, fun m n l hmn hnl hrel => hbad_level m n l hmn hnl hrelÔş®

/-! ## `FinGl` monotonicity under `Finset`-inclusion of the generating family -/

/-- Every block of a finite gluing over `S.toFinFun` is literally a member of `S`. -/
lemma copiesList_toFinFun_subset {S : Finset ScatFun} (t : Fin S.card ÔåÆ Ôäò) :
    ÔêÇ w Ôêê ScatFun.copiesList S.toFinFun t, w Ôêê S := by
  intro w hw
  simp only [ScatFun.copiesList, List.mem_flatMap, List.mem_finRange, List.mem_replicate,
    true_and] at hw
  obtain Ôş¿i, -, rflÔş® := hw
  exact Finset.mem_toList.mp (List.get_mem S.toList _)

/-- **`FinGl` is monotone under `Finset`-inclusion of the generating family.**  A finite gluing
over `S.toFinFun` is a `glList` of blocks all lying in `S` (`copiesList_toFinFun_subset`), hence
(since `S Ôèå S'`) all lying in `S'`; `finGl_glList_of_forall_mem` then places it in
`FinGl S'.toFinFun`, and `finGl_closed_equiv` transfers this along the defining equivalence to
every member of `FinGl S.toFinFun`. -/
theorem FinGl_mono_of_subset {S S' : Finset ScatFun} (h : S Ôèå S') :
    ScatFun.FinGl S.toFinFun Ôèå ScatFun.FinGl S'.toFinFun := by
  intro f hf
  obtain Ôş¿t, ht1, ht2Ôş® := hf
  have hL : ÔêÇ w Ôêê ScatFun.copiesList S.toFinFun t, w Ôêê S' :=
    fun w hw => h (copiesList_toFinFun_subset t w hw)
  have hmem := finGl_glList_of_forall_mem hL
  rw [ÔåÉ ScatFun.Gl_eq_glList_copiesList] at hmem
  exact finGl_closed_equiv _ hmem Ôş¿ht1, ht2Ôş®

/-! ## Monotonicity of `Generators` across a fixed limit-or-zero block -/

/-- `GenBlock G0 C1` is monotone in its `Ôäò`-index (immediate from `GenBlock_subset_succ`). -/
theorem GenBlock_mono (G0 C1 : Finset ScatFun) : Monotone (GenBlock G0 C1) :=
  monotone_nat_of_le_succ (GenBlock_subset_succ G0 C1)

/-- **`Generators` is monotone across a fixed limit-or-zero block.**  For `lam` limit-or-zero,
`Generators (lam+k) Ôèå Generators (lam+n)` whenever `k Ôëñ n`: both sides unfold to `GenBlock
(genBase lam) (centBase1 lam)` at index `k`/`n` (`Ordinal.limitPart_add_natCast`/
`natPart_add_natCast`), so this is `GenBlock_mono`. -/
theorem Generators_mono_of_le {lam : Ordinal.{0}} (hlim : Order.IsSuccLimit lam Ôê¿ lam = 0)
    {k n : Ôäò} (hkn : k Ôëñ n) :
    Generators (lam + k) Ôèå Generators (lam + n) := by
  have hGk : Generators (lam + k) = GenBlock (genBase lam) (centBase1 lam) k := by
    unfold Generators
    rw [Ordinal.limitPart_add_natCast lam k hlim, Ordinal.natPart_add_natCast lam k hlim]
  have hGn : Generators (lam + n) = GenBlock (genBase lam) (centBase1 lam) n := by
    unfold Generators
    rw [Ordinal.limitPart_add_natCast lam n hlim, Ordinal.natPart_add_natCast lam n hlim]
  rw [hGk, hGn]
  exact GenBlock_mono (genBase lam) (centBase1 lam) hkn

/-! ## Finite generation of a level interval `[lam, lam+n]` -/

/-- **A finitely-generated block generates its whole interval.**  For `lam` limit-or-zero and
`n : Ôäò`, if every level `lam+k` (`k Ôëñ n`) is finitely generated by its own `Generators (lam+k)`,
then the whole interval `LevelInter lam (lam+n)` is finitely generated by the top-level family
`Generators (lam+n)` alone.

Every `F` in the interval has `CBRank F.func = lam + k` for a (unique) `k Ôëñ n` ÔÇö extracting `k`
is ordinal arithmetic (`exists_add_of_le` gives the offset `╬┤`, `add_le_add_iff_left` bounds it
by `n`, `Ordinal.lt_omega0` reads it off as a natural number) ÔÇö and `hFG` places `F` in
`FinGl (Generators (lam+k)).toFinFun`, which embeds into `FinGl (Generators (lam+n)).toFinFun`
via `Generators_mono_of_le` and `FinGl_mono_of_subset`.  This is exactly the `hgen` hypothesis
consumed by `finitenessOfCenteredFunctions` (`CenteredFunctions/Finiteness.lean`). -/
theorem LevelInter_finitelyGenerated {lam : Ordinal.{0}} (hlim : Order.IsSuccLimit lam Ôê¿ lam = 0)
    (n : Ôäò)
    (hFG : ÔêÇ k Ôëñ n, ÔêÇ F : ScatFun, CBRank F.func = lam + k ÔåÆ
      F Ôêê FinGl (Generators (lam + k)).toFinFun) :
    ScatFun.LevelInter lam (lam + n) Ôèå ScatFun.FinGl (Generators (lam + n)).toFinFun := by
  intro F hF
  obtain Ôş¿hge, hleÔş® := hF
  obtain Ôş¿╬┤, h╬┤Ôş® := exists_add_of_le hge
  have h╬┤n : ╬┤ Ôëñ (n : Ordinal.{0}) := by
    have h1 : lam + ╬┤ Ôëñ lam + (n : Ordinal.{0}) := h╬┤ Ôû© hle
    exact (add_le_add_iff_left lam).mp h1
  have h╬┤lt : ╬┤ < Ordinal.omega0 :=
    lt_of_le_of_lt h╬┤n (by exact_mod_cast Ordinal.nat_lt_omega0 n)
  obtain Ôş¿k, hkÔş® := Ordinal.lt_omega0.mp h╬┤lt
  have hkn : k Ôëñ n := by exact_mod_cast (hk Ôû© h╬┤n : (k : Ordinal.{0}) Ôëñ (n : Ordinal.{0}))
  have hFk : F Ôêê FinGl (Generators (lam + k)).toFinFun := hFG k hkn F (by rw [h╬┤, hk])
  exact FinGl_mono_of_subset (Generators_mono_of_le hlim hkn) hFk

end ScatFun

end
